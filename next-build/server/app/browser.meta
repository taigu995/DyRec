{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/browser/layout,_N_T_/browser/page,_N_T_/browser"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/browser/__PAGE__",
    "/browser",
    "/_index",
    "/_head"
  ]
}