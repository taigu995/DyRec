{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/recordings/layout,_N_T_/recordings/page,_N_T_/recordings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/recordings/__PAGE__",
    "/recordings",
    "/_index",
    "/_head"
  ]
}