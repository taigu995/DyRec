{
  "name": "dyrec",
  "version": "1.0.0",
  "description": "抖音直播自动录制管理工具",
  "private": true,
  "main": "electron/main.js",
  "author": "DyRec",
  "scripts": {
    "build": "bash ./scripts/build.sh",
    "dev": "bash ./scripts/dev.sh",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint",
    "lint:build": "eslint . --quiet",
    "start": "bash ./scripts/start.sh",
    "ts-check": "tsc -p tsconfig.json",
    "validate": "pnpm run --parallel '/^(ts-check|lint:build)$/'",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5000 && electron .\"",
    "electron:build": "pnpm build && electron-builder --win --x64",
    "electron:build:dir": "pnpm build && electron-builder --win --x64 --dir",
    "electron:start": "pnpm build && electron ."
  },
  "build": {
    "appId": "com.dyrec.app",
    "productName": "DyRec",
    "copyright": "Copyright © 2026 DyRec",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/resources"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.ts",
      "public/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": ".next",
        "to": "app/.next"
      },
      {
        "from": "public",
        "to": "app/public"
      },
      {
        "from": "node_modules",
        "to": "app/node_modules"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DyRec",
      "installerIcon": "electron/resources/icon.ico",
      "uninstallerIcon": "electron/resources/icon.ico",
      "installerHeaderIcon": "electron/resources/icon.ico"
    },
    "asar": false
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/lib-storage": "^3.958.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "2.95.3",
    "@swc/helpers": "^0.5.15",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "coze-coding-dev-sdk": "^0.7.24",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "douyin-danma-listener": "^0.4.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.468.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "protobufjs": "^8.6.6",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "styled-jsx": "^5.1.6",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "unzipper": "^0.12.5",
    "vaul": "^1.1.2",
    "ws": "^8.21.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@electron/rebuild": "^4.1.0",
    "@react-dev-inspector/babel-plugin": "^2.0.1",
    "@react-dev-inspector/middleware": "^2.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^8.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "only-allow": "^1.2.2",
    "react-dev-inspector": "^2.0.1",
    "shadcn": "latest",
    "tailwindcss": "^4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  }
}
